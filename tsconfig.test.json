{
  "compilerOptions": {
    "target": "ES5",
    "module": "ES2022",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": false,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "sourceMap": true
  },
  "include": [
    "src/**/*",
    "tests/**/*.ts",
    "test-main.ts"
  ]
}
