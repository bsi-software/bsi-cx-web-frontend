{
  "compilerOptions": {
    "target": "ES5",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "typeRoots": [
      "./node_modules/@types",
      "./node_modules/expr-eval/parser.d.ts"]
  },
  "include": [
    "src/**/*"
  ]
}
